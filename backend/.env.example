# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/localnews

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Auth
JWT_SECRET=change-me-to-a-random-32-byte-string-base64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# AI Services (stubs used if empty)
GEMINI_API_KEY=
GENERATION_MODEL=gemini-3.1-pro
ELEVENLABS_API_KEY=

# Media
MEDIA_STORAGE_PATH=./uploads

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8000/api/auth/google/callback

# Rate Limiting (all optional — sensible defaults)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=1m
RATE_LIMIT_SEARCH_MAX=35
RATE_LIMIT_SEARCH_WINDOW=1m
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_WRITE_WINDOW=1m
RATE_LIMIT_READ_MAX=60
RATE_LIMIT_READ_WINDOW=1m
RATE_LIMIT_SSE_MAX=3
RATE_LIMIT_EDITOR_MULT=2.0
RATE_LIMIT_ADMIN_MULT=5.0
